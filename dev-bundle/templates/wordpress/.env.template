PROJECT_NAME={{PROJECT_NAME}}
COMPOSE_PROJECT_NAME={{PROJECT_NAME}}

# WordPress Configuration (LocalWP Compatible)
WP_PORT={{WP_PORT}}
WP_HTTPS_PORT={{WP_HTTPS_PORT}}
WP_URL=http://localhost:{{WP_PORT}}
WP_HOME=http://localhost:{{WP_PORT}}
WP_SITEURL=http://localhost:{{WP_PORT}}

# Database Configuration
DB_HOST=mysql
DB_PORT={{DB_PORT}}
DB_NAME={{PROJECT_NAME}}_db
DB_USER={{PROJECT_NAME}}_user
DB_PASSWORD=secure_password_123
DB_ROOT_PASSWORD=root_password_123

# phpMyAdmin Configuration
PMA_PORT={{PMA_PORT}}

# Mailhog Configuration
MAIL_PORT={{MAIL_PORT}}
SMTP_PORT={{SMTP_PORT}}

# WordPress Admin (Auto-Install)
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin123
WP_ADMIN_EMAIL=admin@{{PROJECT_NAME}}.local
WP_TITLE={{PROJECT_NAME}}

# PHP Configuration
PHP_VERSION=8.1
PHP_MEMORY_LIMIT=256M
PHP_MAX_UPLOAD=64M
PHP_MAX_POST=64M

# Environment
WP_ENVIRONMENT_TYPE=local
WP_DEBUG=true
WP_DEBUG_LOG=true
WP_DEBUG_DISPLAY=false